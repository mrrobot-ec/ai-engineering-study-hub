  "weeks": [
    {
      "week": 1,
      "title": "Context inventory and evaluation",
      "goal": "Make every context source, owner, permission, freshness rule, and token cost visible.",
      "time": "6–8 hours",
      "deliverable": "Context map plus 30–50 golden conversations covering long threads, stale facts, conflicts, injection, and permissions.",
      "project": {
        "title": "Context Observatory",
        "summary": "Build a small agent gateway that records every context source, token cost, freshness decision, and permission check for each response.",
        "acceptance": ["Run 30–50 golden conversations", "Produce a per-turn context ledger", "Write a failure report for stale, conflicting, and unauthorized context"]
      },
      "resources": [
        {"label": "Job-aligned track", "kind": "note", "path": "JOB-ALIGNED-LEARNING-PATH.md", "role": "start"},
        {"label": "Context rearchitecture design", "kind": "note", "path": "workspace/agent-context-rearchitecture-design.md", "role": "build"},
        {"label": "Agentic context engineering", "kind": "pdf", "path": "papers/context-memory/2025-agentic-context-engineering.pdf", "role": "deep"},
        {"label": "LangChain context engineering", "kind": "external", "url": "https://docs.langchain.com/oss/python/langchain/context-engineering", "role": "build"}
      ]
    },
    {
      "week": 2,
      "title": "LangGraph persistence and replay",
      "goal": "Understand state, threads, checkpoints, interrupts, replay, and safe graph resumption.",
      "time": "6–10 hours",
      "deliverable": "Restart/resume tests at graph boundaries and a state-schema versioning note.",
      "project": {
        "title": "Replay-Safe Approval Agent",
        "summary": "Implement a LangGraph workflow that pauses for approval, survives a process restart, and safely resumes from checkpoints.",
        "acceptance": ["Restart successfully at every checkpoint", "Test one state-schema migration", "Demonstrate interrupt, approval, and replay"]
      },
      "resources": [
        {"label": "LangGraph orchestration guide", "kind": "note", "path": "workspace/LANGGRAPH_ORCHESTRATION.md", "role": "build"},
        {"label": "LangGraph persistence docs", "kind": "external", "url": "https://docs.langchain.com/oss/python/langgraph/persistence", "role": "start"},
        {"label": "MemGPT", "kind": "pdf", "path": "papers/context-memory/2023-memgpt.pdf", "role": "deep"},
        {"label": "LongMemEval", "kind": "pdf", "path": "papers/context-memory/2024-longmemeval.pdf", "role": "frontier"}
      ]
    },
    {
      "week": 3,
      "title": "Safe side effects and agent boundaries",
      "goal": "Separate model decisions, runtime context, domain writes, approvals, and idempotency keys.",
      "time": "6–10 hours",
      "deliverable": "Effect ledger and tests proving a replay cannot duplicate a user-visible write.",
      "project": {
        "title": "Effect Ledger",
        "summary": "Create a tool-execution boundary that records proposed effects, approvals, idempotency keys, and final outcomes.",
        "acceptance": ["Replay causes no duplicate writes", "Sensitive actions require explicit approval", "Every effect has an auditable lifecycle"]
      },
      "resources": [
        {"label": "OpenAI agents guide", "kind": "pdf", "path": "guides/openai-a-practical-guide-to-building-agents.pdf", "role": "start"},
        {"label": "AgentDojo security evaluation", "kind": "pdf", "path": "papers/security-protocols/2024-agentdojo-prompt-injection-agents.pdf", "role": "deep"},
        {"label": "ReAct", "kind": "pdf", "path": "papers/agents/2022-react-reasoning-and-acting.pdf", "role": "reference"},
        {"label": "OpenAI Agents SDK docs", "kind": "external", "url": "https://openai.github.io/openai-agents-python/", "role": "build"}
      ]
    },
    {
      "week": 4,
      "title": "Tracing and eval gates",
      "goal": "Make traces, graders, cost, latency, and regressions part of the development loop.",
      "time": "6–8 hours",
      "deliverable": "Trace schema, context budget ledger, task graders, and a release threshold.",
      "project": {
        "title": "Agent Evaluation Gate",
        "summary": "Build a repeatable evaluation harness that scores task success, safety, latency, and token cost before a release.",
        "acceptance": ["Version a representative golden set", "Implement deterministic and model-based graders", "Fail CI when a release threshold regresses"]
      },
      "resources": [
        {"label": "LLM evals FAQ", "kind": "pdf", "path": "guides/hamel-llm-evals-faq.pdf", "role": "start"},
        {"label": "LLM-as-judge MT-Bench", "kind": "pdf", "path": "papers/evals-safety/2023-llm-as-judge-mtbench.pdf", "role": "deep"},
        {"label": "ML Test Score", "kind": "pdf", "path": "papers/production-systems/2017-ml-test-score.pdf", "role": "build"}
      ]
    },
    {
      "week": 5,
      "title": "Framework comparison",
      "goal": "Learn the concepts that transfer across LangGraph, LangChain, ADK, Pydantic AI, and OpenAI Agents.",
      "time": "8–12 hours",
      "deliverable": "One small approval workflow implemented in two runtimes and compared by measured trade-offs.",
      "project": {
        "title": "Framework Bake-Off",
        "summary": "Build the same approval workflow in LangGraph and one second framework, then compare behavior instead of marketing claims.",
        "acceptance": ["Use an identical task and tool contract", "Compare traces, recovery, testing, and ergonomics", "Publish an architecture decision record"]
      },
      "resources": [
        {"label": "Google ADK docs", "kind": "external", "url": "https://google.github.io/adk-docs/", "role": "start"},
        {"label": "LangGraph source", "kind": "code", "path": "framework-code/langgraph", "role": "reference"},
        {"label": "Google ADK Python source", "kind": "code", "path": "framework-code/google-adk-python", "role": "build"},
        {"label": "Pydantic AI source", "kind": "code", "path": "framework-code/pydantic-ai", "role": "frontier"}
      ]
    },
    {
      "week": 6,
      "title": "Kafka correctness",
      "goal": "Understand partitions, consumer groups, offsets, retries, DLQs, replay, lag, and backpressure.",
      "time": "8–12 hours",
      "deliverable": "Crash matrix proving the intended delivery semantics for one consumer workflow.",
      "project": {
        "title": "Kafka Failure Lab",
        "summary": "Build an event consumer and deliberately crash it before and after processing and offset commits.",
        "acceptance": ["Demonstrate retries, DLQ, and replay", "Measure lag and backpressure", "Document the observed delivery semantics"]
      },
      "resources": [
        {"label": "Kafka paper", "kind": "pdf", "path": "papers/distributed-systems/2011-kafka-distributed-messaging.pdf", "role": "start"},
        {"label": "Kafka design documentation", "kind": "external", "url": "https://kafka.apache.org/documentation/#design", "role": "build"},
        {"label": "Google File System", "kind": "pdf", "path": "papers/distributed-systems/2003-google-file-system.pdf", "role": "deep"},
        {"label": "MapReduce", "kind": "pdf", "path": "papers/distributed-systems/2004-mapreduce.pdf", "role": "reference"}
      ]
    },
    {
      "week": 7,
      "title": "Postgres, Redis, and transactional boundaries",
      "goal": "Use transactions, constraints, outbox/inbox patterns, leases, fencing, and cache invalidation deliberately.",
      "time": "8–12 hours",
      "deliverable": "Transactional deduplication plus Redis lock/lease failure tests.",
      "project": {
        "title": "Transactional Outbox Service",
        "summary": "Create a Postgres-backed command service with an atomic outbox, idempotent consumer, and Redis lease protection.",
        "acceptance": ["Persist domain change and event atomically", "Deduplicate repeated deliveries", "Test an expired lease with a fencing token"]
      },
      "resources": [
        {"label": "Dynamo", "kind": "pdf", "path": "papers/distributed-systems/2007-dynamo.pdf", "role": "start"},
        {"label": "FoundationDB", "kind": "pdf", "path": "papers/distributed-systems/2021-foundationdb.pdf", "role": "deep"},
        {"label": "Database Internals access", "kind": "external", "url": "https://www.oreilly.com/library/view/database-internals/9781492040330/", "role": "reference"}
      ]
    },
    {
      "week": 8,
      "title": "Temporal durable execution",
      "goal": "Make long-lived workflows recoverable across process death, retries, deploys, and timeouts.",
      "time": "8–12 hours",
      "deliverable": "One durable workflow with activity idempotence, retry policy, timeout policy, and recovery demo.",
      "project": {
        "title": "Durable Research Workflow",
        "summary": "Implement a multi-step Temporal workflow that gathers sources, waits for review, and publishes a result after recovery.",
        "acceptance": ["Make every activity idempotent", "Configure retries and timeouts deliberately", "Kill workers mid-run and prove recovery"]
      },
      "resources": [
        {"label": "Temporal durable execution guide", "kind": "pdf", "path": "papers/distributed-systems/2025-temporal-durable-execution.pdf", "role": "start"},
        {"label": "Raft", "kind": "pdf", "path": "papers/distributed-systems/2014-raft.pdf", "role": "deep"},
        {"label": "ZooKeeper", "kind": "pdf", "path": "papers/distributed-systems/2010-zookeeper.pdf", "role": "reference"}
      ]
    },
    {
      "week": 9,
      "title": "Recommendation data contracts",
      "goal": "Separate exposure, outcome, negative feedback, delayed labels, and point-in-time features.",
      "time": "6–10 hours",
      "deliverable": "Exposure/outcome schema, leakage tests, retention rules, and a reproducible dataset.",
      "project": {
        "title": "Recommendation Event Contract",
        "summary": "Design and generate a small event dataset that correctly links impressions, choices, delayed outcomes, and point-in-time features.",
        "acceptance": ["Add an automated leakage test", "Represent delayed and negative feedback", "Rebuild the same training snapshot reproducibly"]
      },
      "resources": [
        {"label": "Recommender book audit", "kind": "note", "path": "RECOMMENDER-SYSTEMS-BOOK-AUDIT.md", "role": "start"},
        {"label": "Google recommendation course", "kind": "external", "url": "https://developers.google.com/machine-learning/recommendation", "role": "build"},
        {"label": "Information Retrieval", "kind": "pdf", "path": "books/introduction-to-information-retrieval.pdf", "role": "reference"}
      ]
    },
    {
      "week": 10,
      "title": "Candidate generation",
      "goal": "Build multiple candidate sources and measure per-source recall, freshness, and latency.",
      "time": "8–12 hours",
      "deliverable": "Popularity/rules plus vector or two-tower retrieval baseline with recall@k.",
